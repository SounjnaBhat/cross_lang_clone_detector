          "input_type": "array",
          "output_type": "integer",
          "transformation": "selection",
          "data_structure": "array",
          "patterns": ["SELECTION", "TRAVERSAL"]
        },
        "Sorting": {
          "description": "Sorts an array in ascending order.",
