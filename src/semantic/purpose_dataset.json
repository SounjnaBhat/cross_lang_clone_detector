          "description": "Counts frequency of elements in a collection.",
          "templates": ["frequency_count", "element_frequency", "count_occurrences"],
          "input_type": "array",
          "output_type": "map",
          "transformation": "counting",
          "data_structure": "array",
          "patterns": ["COUNTING", "TRAVERSAL"]
        }
      }
    },
    "String": {
