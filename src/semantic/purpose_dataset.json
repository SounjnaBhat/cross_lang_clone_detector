{
  "domains": {
    "Numeric": {
      "intents": {
        "Factorial": {
          "description": "Computes the factorial of a positive integer.",
          "templates": ["factorial", "factorial_recursive", "factorial_iterative", "fact"],
          "input_type": "integer",
          "output_type": "integer",
          "transformation": "multiplicative_accumulation",
          "data_structure": "scalar",
          "patterns": ["ACCUMULATION", "RECURSION", "MULTIPLICATIVE_ACCUMULATION"]
        },
        "Fibonacci": {
          "description": "Computes the Fibonacci number at sequence index n.",
          "templates": ["fibonacci", "fib", "fibonacci_recursive", "fibonacci_iterative"],
          "input_type": "integer",
          "output_type": "integer",
          "transformation": "additive_sequence",
          "data_structure": "scalar",
          "patterns": ["ACCUMULATION", "RECURSION"]
        },
        "Prime": {
          "description": "Checks if a number is prime.",
          "templates": ["is_prime", "prime_check", "prime"],
          "input_type": "integer",
          "output_type": "boolean",
          "transformation": "primality_test",
          "data_structure": "scalar",
          "patterns": ["SELECTION", "TRAVERSAL"]
        },
        "GCD": {
          "description": "Calculates the greatest common divisor of two integers.",
          "templates": ["gcd", "greatest_common_divisor"],
          "input_type": "integer_pair",
          "output_type": "integer",
          "transformation": "euclidean_division",
          "data_structure": "scalar",
          "patterns": ["TRAVERSAL", "ACCUMULATION"]
        },
        "LCM": {
          "description": "Calculates the least common multiple of two integers.",
          "templates": ["lcm", "least_common_multiple"],
          "input_type": "integer_pair",
          "output_type": "integer",
          "transformation": "lcm_calculation",
          "data_structure": "scalar",
          "patterns": ["ACCUMULATION"]
        },
        "Power": {
          "description": "Computes base raised to exponent power.",
          "templates": ["power", "exponentiate", "pow"],
          "input_type": "integer_pair",
          "output_type": "integer",
          "transformation": "multiplicative_accumulation",
          "data_structure": "scalar",
          "patterns": ["MULTIPLICATIVE_ACCUMULATION"]
        },
        "Matrix Operations": {
          "description": "Performs operations like multiplication or addition on matrices.",
          "templates": ["matrix_multiply", "matrix_add", "matrix"],
          "input_type": "matrices",
          "output_type": "matrix",
          "transformation": "matrix_transformation",
          "data_structure": "array_2d",
          "patterns": ["TRAVERSAL", "ACCUMULATION"]
        }
      }
    },
